# AgentForge Configuration
# Copy to .env and fill in your API keys

# Anthropic (Claude) - for planner and claude-code agents
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI - for codex agents and GPT planner
OPENAI_API_KEY=sk-...

# Google AI - for Gemini planner
GOOGLE_API_KEY=AIza...

# Ollama - local model server
OLLAMA_URL=http://localhost:11434

# Default planner model: claude | openai | gemini | ollama | claudel
AGENTFORGE_PLANNER=claude

# Default Ollama model for planning
AGENTFORGE_OLLAMA_MODEL=llama3.2

# Optional Ollama cloud endpoint + preferred cloud model list (comma-separated)
# If set, AgentForge tries cloud models first, then local models
AGENTFORGE_OLLAMA_CLOUD_URL=
AGENTFORGE_OLLAMA_CLOUD_MODELS=

# Optional extra directories Claude/Claudel should always be allowed to access
AGENTFORGE_EXTRA_DIRS=

# Web UI port
AGENTFORGE_WEB_PORT=3000

# API server port
AGENTFORGE_API_PORT=3001
