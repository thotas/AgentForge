{
  "name": "agentforge",
  "version": "1.0.0",
  "private": true,
  "description": "Multi-Model Agent Orchestrator - Plan, spawn, and manage AI agents across Claude, Codex, Gemini, and Ollama",
  "workspaces": [
    "packages/core",
    "packages/cli",
    "packages/web"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "build:core": "npm run build -w packages/core",
    "build:cli": "npm run build -w packages/cli",
    "build:web": "npm run build -w packages/web",
    "dev:web": "npm run dev -w packages/web",
    "setup": "npm install && npm run build",
    "agentforge": "node packages/cli/dist/index.js"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
